---
/**
 * Image with optional caption for MDX blog posts.
 *
 * For Astro-optimized images (recommended), import the image and pass the
 * imported object — Astro will convert to WebP, generate srcset, etc.:
 *
 *   import coffeeBean from './coffee-bean-planner.jpg';
 *   <Figure src={coffeeBean} alt="Description" caption="What you're looking at" />
 *
 * Place the image file next to the .mdx file that uses it.
 *
 * For plain paths (public/ or external URLs) the <img> fallback is used,
 * but no optimization is applied:
 *
 *   <Figure src="/images/photo.jpg" alt="Description" caption="..." />
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src?: string | ImageMetadata;
  alt?: string;
  caption?: string;
  width?: number;
}

const { src, alt = '', caption, width } = Astro.props;
const isLocal = src && typeof src === 'object';
---

<figure class="blog-figure">
  {src ? (
    isLocal ? (
      <Image
        src={src as ImageMetadata}
        alt={alt}
        width={width ?? (src as ImageMetadata).width}
        style={width ? `width: ${width}px` : undefined}
      />
    ) : (
      <img
        src={src as string}
        alt={alt}
        style={width ? `width: ${width}px` : undefined}
      />
    )
  ) : (
    <div class="blog-figure-placeholder" aria-label={alt} role="img">
      <span class="blog-figure-placeholder-icon">✦</span>
      {alt && <p class="blog-figure-placeholder-text">{alt}</p>}
    </div>
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .blog-figure-placeholder {
    width: 100%;
    min-height: 220px;
    background: color-mix(in srgb, var(--color-terracotta) 6%, var(--color-cream));
    border: 1px dashed var(--color-border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem;
  }

  .blog-figure-placeholder-icon {
    font-size: 1.2rem;
    color: var(--color-muted);
    opacity: 0.4;
  }

  .blog-figure-placeholder-text {
    font-size: 0.78rem;
    color: var(--color-muted);
    font-style: italic;
    text-align: center;
    max-width: 400px;
    line-height: 1.5;
    margin: 0;
  }
</style>

<style>
  .blog-figure {
    margin: 2.5rem 0;
    text-align: center;
  }

  .blog-figure img {
    max-width: 100%;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    display: block;
    margin: 0 auto;
  }

  .blog-figure figcaption {
    margin-top: 0.7rem;
    font-size: 0.78rem;
    color: var(--color-muted);
    font-style: italic;
    line-height: 1.5;
  }
</style>
