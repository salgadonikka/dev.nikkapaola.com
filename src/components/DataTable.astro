---
/**
 * DataTable.astro
 * Styled reference table for use in MDX blog posts.
 * Use for TL;DR quick-reference tables — more visual than the default .prose table.
 *
 * Props:
 *   headers: string[]          — column header labels
 *   rows:    string[][]        — 2D array of cell values (supports basic HTML strings)
 *   caption?: string           — optional small label shown above the table
 *   highlightFirst?: boolean   — if true, first column is rendered in ink/bold (default: true)
 */

interface Props {
  headers: string[];
  rows: string[][];
  caption?: string;
  highlightFirst?: boolean;
}

const { headers, rows, caption, highlightFirst = true } = Astro.props;
---

<div class="data-table-wrap">
  {caption && <p class="data-table__caption">{caption}</p>}
  <div class="data-table__scroll">
    <table class="data-table">
      <thead>
        <tr>
          {headers.map((h) => <th>{h}</th>)}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            {row.map((cell, i) => (
              <td class:list={[{ 'data-table__first-col': i === 0 && highlightFirst }]}
                  set:html={cell} />
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .data-table-wrap {
    margin: 28px 0;
  }

  .data-table__caption {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-bottom: 10px;
    font-style: italic;
  }

  .data-table__scroll {
    overflow-x: auto;
    border-radius: 10px;
    border: 1px solid var(--color-border);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .data-table thead tr {
    background: var(--color-warm-white);
  }

  .data-table th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    border-bottom: 2px solid var(--color-border);
    white-space: nowrap;
  }

  .data-table td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-ink-soft);
    line-height: 1.6;
    vertical-align: top;
    font-weight: 300;
  }

  .data-table tbody tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover td {
    background: #fdfaf6;
  }

  .data-table__first-col {
    font-weight: 500 !important;
    color: var(--color-ink) !important;
  }

  /* Dark mode */
  :global(html[data-theme="dark"]) .data-table__scroll {
    border-color: rgba(255,255,255,0.1);
  }
  :global(html[data-theme="dark"]) .data-table thead tr {
    background: rgba(255,255,255,0.04);
  }
  :global(html[data-theme="dark"]) .data-table td,
  :global(html[data-theme="dark"]) .data-table th {
    border-color: rgba(255,255,255,0.08);
  }
  :global(html[data-theme="dark"]) .data-table tbody tr:hover td {
    background: rgba(255,255,255,0.03);
  }
</style>
