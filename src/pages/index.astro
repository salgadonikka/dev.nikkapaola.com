---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { identity, status, contactLinks } from "../data/portfolioData.js";
import { metaDescription } from "../data/portfolioData.js";
import portfolioPhoto from "../assets/portfolio-photo.jpg";
import secondaryPhoto from "../assets/secondary-photo.jpg";
import "../styles/landing.css";

const pageTitle = `${identity.name} — Full-Stack Software Engineer`;
const emailLink = contactLinks.find((l) => l.type === "email");
---

<!doctype html>
<html lang="en" class="lp-html">
  <head>
    <BaseHead title={pageTitle} description={metaDescription} />
    <script is:inline>
      document.documentElement.dataset.theme = "light";
    </script>
  </head>

  <body>
    <!-- ══ HEADER ══ -->
    <SiteHeader />

    <!-- ══ HERO ══ -->
    <section class="lp-hero" id="hero" aria-label="Introduction">
      <div class="lp-hero-inner">
        <!-- Left: text content -->
        <div class="lp-hero-text">
          <h1 class="lp-greeting">Hello, I'm Nikka!</h1>
          <p class="lp-role">
            Full Stack Software Engineer<br /><span class="lp-role-amp"
              >&amp;</span
            > People Manager
          </p>
          <p class="lp-bio">
            I build software and lead the engineers who build it with me. AI's
            in the loop wherever it earns its place, whether that's pairing on
            code, speeding up test coverage, or just helping me think through a
            tricky 1-on-1.
          </p>

          <div class="lp-hero-foot">
            <div class="lp-avail-badge">
              <span class="pulse-dot" aria-hidden="true"></span>
              {status.availability} · {status.location}
            </div>
            <div class="lp-cta-group">
              <a href="/portfolio" class="lp-btn-primary">See my Portfolio</a>
              {
                emailLink && (
                  <a href={emailLink.href} class="lp-btn-ghost">
                    Get in Touch
                  </a>
                )
              }
            </div>
          </div>
        </div>

        <!-- Right: photo (hover swaps to secondary) -->
        <div class="lp-hero-photo" aria-hidden="true">
          <Image
            src={portfolioPhoto}
            alt={identity.photoAlt ?? `${identity.name} profile photo`}
            class="lp-hero-photo-img lp-photo-primary"
            width={440}
            height={440}
          />
          <Image
            src={secondaryPhoto}
            alt=""
            class="lp-hero-photo-img lp-photo-hover"
            width={440}
            height={440}
          />
        </div>
      </div>
    </section>
  </body>
</html>
