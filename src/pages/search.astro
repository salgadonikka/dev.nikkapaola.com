---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Search - ${SITE_TITLE}`}
      description={`Search all posts on ${SITE_TITLE}`}
    />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  </head>
  <body>
    <Header />

    <main>
      <div class="page-header">
        <div class="page-eyebrow">Search</div>
        <h1 class="page-title">Find a <em>post</em></h1>
      </div>

      <div id="search-wrap">
        <div id="search"></div>
        <p id="search-dev-notice" class="dev-notice" style="display:none">
          Search is only available after running <code>npm run build</code>. In
          dev mode, use <a href="/blog">the blog listing</a> to browse posts.
        </p>
      </div>
    </main>

    <Footer />

    <script is:inline>
      (async function () {
        try {
          await import("/pagefind/pagefind-ui.js");
          const PagefindUI = window.PagefindUI;
          new PagefindUI({
            element: "#search",
            showImages: true,
            excerptLength: 20,
            resetStyles: false,
          });
        } catch (err) {
          console.error("[pagefind] failed to load:", err);
          var notice = document.getElementById("search-dev-notice");
          if (notice) notice.style.display = "block";
          var el = document.getElementById("search");
          if (el) el.style.display = "none";
        }
      })();
    </script>
  </body>
</html>

<style>
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 60px 100px;
  }

  .page-header {
    margin-bottom: 48px;
  }

  .page-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    font-weight: 500;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .page-eyebrow::before {
    content: "";
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--color-terracotta);
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.1;
  }

  .page-title em {
    font-style: italic;
    color: var(--color-terracotta);
  }

  /* ── PAGEFIND UI OVERRIDES ── */
  :global(.pagefind-ui) {
    --pagefind-ui-font: var(--font-sans);
    --pagefind-ui-primary: var(--color-terracotta);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-cream);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-warm-white);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 3px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-scale: 0.9;
  }

  .dev-notice {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.7;
    padding: 24px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-warm-white);
  }

  .dev-notice code {
    font-size: 0.85em;
    background: var(--color-border);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .dev-notice a {
    color: var(--color-terracotta);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    main {
      padding: 100px 24px 80px;
    }
  }
</style>
