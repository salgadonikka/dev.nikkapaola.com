---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

function calcReadingTime(body: string): string {
	// Strip markdown/MDX syntax and count words
	const cleaned = body
		.replace(/^---[\s\S]*?---/, '')  // frontmatter
		.replace(/```[\s\S]*?```/g, ' ') // code blocks
		.replace(/`[^`]+`/g, ' ')        // inline code
		.replace(/<[^>]+>/g, ' ')        // HTML/JSX tags
		.replace(/!\[[^\]]*\]\([^)]*\)/g, ' ') // images
		.replace(/\[[^\]]*\]\([^)]*\)/g, ' ')  // links (keep text, drop URL)
		.replace(/[#*_~>|\\]/g, ' ');    // markdown syntax chars

	const words = cleaned.trim().split(/\s+/).filter(Boolean).length;
	const minutes = Math.max(1, Math.ceil(words / 238));
	return `${minutes} min read`;
}

const readingTime = post.data.readingTime ?? calcReadingTime(post.body ?? '');
---

<BlogPost id={post.id} {...post.data} readingTime={readingTime}>
	<Content />
</BlogPost>
